# Caddy reverse proxy for akganesh.com (auto-HTTPS via Let's Encrypt).
# Place at /etc/caddy/Caddyfile on the VPS, then: systemctl reload caddy
akganesh.com, www.akganesh.com {
	# API + uploaded images -> Express
	handle /api/* {
		reverse_proxy 127.0.0.1:4000
	}
	handle /uploads/* {
		reverse_proxy 127.0.0.1:4000
	}
	# everything else -> Next.js
	handle {
		reverse_proxy 127.0.0.1:3000
	}
	encode gzip
}
